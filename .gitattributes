# 모든 텍스트 파일 LF로 통일 (Windows/macOS 줄바꿈 충돌 방지)
* text=auto eol=lf

*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.swift text eol=lf
*.podspec text eol=lf

# 바이너리 파일
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ttf binary
*.otf binary
*.jar binary
*.keystore binary
